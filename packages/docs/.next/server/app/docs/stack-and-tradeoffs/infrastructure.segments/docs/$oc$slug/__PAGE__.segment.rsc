17:["$","p",null,{"children":["Port ",["$","code",null,{"children":"3000"}]," is published to the host (",["$","code",null,{"children":"0.0.0.0:3000"}],"). Teammates connect at ",["$","code",null,{"children":"http://134.122.32.45:3000"}],"."]}]
18:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"tradeoffs-we-accepted","children":[["$","a",null,{"data-card":"","href":"#tradeoffs-we-accepted","className":"peer","children":"Tradeoffs We Accepted"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
19:["$","p",null,{"children":[["$","strong",null,{"children":"Single point of failure."}]," If the droplet goes down, all comms cease. There is no failover. For a hackathon demo, acceptable. Production would require at minimum a health-monitored standby or managed hosting with SLAs."]}]
1a:["$","p",null,{"children":[["$","strong",null,{"children":"No TLS in development."}]," Traffic between clients and the relay server is plain HTTP/WebSocket during development. The nginx config and SSL certificate setup are ready but deferred. For a demo over a local network or managed demo environment, acceptable."]}]
1b:["$","p",null,{"children":[["$","strong",null,{"children":"Manual deployment."}]," ",["$","code",null,{"children":"git pull && docker compose up --build -d"}]," is the deployment process. No CI/CD, no rollback. A broken push means manual ssh and ",["$","code",null,{"children":"docker compose logs"}]," diagnosis. For one week, this is fine."]}]
1c:["$","p",null,{"children":[["$","strong",null,{"children":"No automated backups."}]," The Postgres volume (",["$","code",null,{"children":"pgdata"}],") has no automated backup. The database contains development/hackathon data only — losing it is an inconvenience, not a crisis."]}]
