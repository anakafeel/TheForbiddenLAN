4f:["$","p",null,{"children":["In v1 there is no user creation UI in the portal — users self-register via ",["$","code",null,{"children":"POST /auth/register"}]," on the mobile app or via ",["$","code",null,{"children":"curl"}],". The portal is read-only for user records."]}]
