urrentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}],"\n",["$","p",null,{"children":"PTT is half-duplex: one speaker per talkgroup at a time. The architectural challenge is arbitration. This page explains why server-side grant/deny is incompatible with satellite latency, and what we do instead."}],"\n",["$","hr",null,{}],"\n",["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-server-grantdeny-is-out","children":[["$","a",null,{"data-card":"","href":"#why-server-grantdeny-is-out","className":"peer","children":"Why Server Grant/Deny Is Out"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}],"\n",["$","p",null,{"children":"At 500–1500 ms one-way satellite latency, a server-issued FLOOR_GRANT means:"}],"\n",["$","ol",null,{"children":["\n",["$","li",null,{"children":"User presses PTT"}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"PTT_REQUEST"}]," travels to server: +500–1500 ms"]}],"\n",["$","li",null,{"children":["Server decides and sends ",["$","code",null,{"children":"FLOOR_GRANT"}]," back: +500–1500 ms"]}],"\n",["$","li",null,{"children":["User's device receives grant: ",["$","strong",null,{"children":"1–3 seconds after button press"}]]}],"\n"]}],"\n",["$","p",null,{"children":"Professional PTT radio users expect sub-100 ms from button press to transmit. A 1–3 second wait is unusable in an operational environment. TETRA, DMR, and every deployed PTT system avoid this."}],"\n",["$","p",null,{"children":["$","strong",null,{"children":["The server does not send ","$L2b"," or ","$L2c"," in v1. It fans out ","$L2d"," messages only."]}]}],"\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49"],"className":"prose"}]],"$L4a","$L4b","$L4c"]}]]}],"$L4d"]}]
