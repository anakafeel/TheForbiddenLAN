{
  "name": "forbiddenlan",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup:local": "./scripts/setup-local.sh",
    "setup:doctor": "./scripts/setup-local.sh",
    "dev:server": "nx serve server",
    "dev:mobile": "nx serve mobile",
    "dev:admin": "pnpm --filter @forbiddenlan/mobile exec expo start --web",
    "dev:docs": "nx serve docs",
    "build:comms": "nx build comms",
    "build:all": "nx run-many --target=build --all",
    "test:all": "nx run-many --target=test --all",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed",
    "lint:all": "nx run-many --target=lint --all",
    "android": "cd packages/mobile && expo run:android",
    "ios": "cd packages/mobile && expo run:ios"
  },
  "devDependencies": {
    "@nx/eslint": "18.0.0",
    "@nx/js": "18.0.0",
    "@nx/node": "18.0.0",
    "@nx/react": "18.0.0",
    "@nx/vite": "18.0.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "eslint": "8.57.0",
    "nx": "18.0.0",
    "typescript": "5.3.3"
  },
  "pnpm": {
    "overrides": {
      "strip-ansi-cjs": "npm:strip-ansi@^6.0.1",
      "string-width-cjs": "npm:string-width@^4.2.0",
      "wrap-ansi-cjs": "npm:wrap-ansi@^7.0.0"
    }
  },
  "dependencies": {
    "expo": "~54.0.33",
    "fumadocs-core": "^14.2.9",
    "fumadocs-mdx": "^14.2.9",
    "fumadocs-ui": "^14.2.9",
    "next": "16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "^2.0.0",
    "react-native-quick-crypto": "^1.0.15",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.7.4",
    "tailwindcss": "^4.0.0"
  }
}
