",["$","p",null,{"children":[["$","strong",null,{"children":"React Native + Expo SDK 54 (Development Build, Android-first)."}]," Same ",["$","code",null,{"children":".jsx"}]," source files compile to browser (via Vite + react-native-web), Android (via Metro + Gradle), and iOS (via Metro + Xcode — currently excluded from active development)."]}],"\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c"],"className":"prose"}]],"$L1d","$L1e","$L1f"]}]]}],"$L20"]}],["$L21","$L22"],"$L23"]}],"loading":null,"isPartial":false}
