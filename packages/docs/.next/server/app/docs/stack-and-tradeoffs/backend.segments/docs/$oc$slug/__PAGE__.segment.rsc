d:["$","ul",null,{"children":["\n",["$","li",null,{"children":"The team is building in a one-week hackathon. Every technology decision has to ship fast."}],"\n",["$","li",null,{"children":"The server must handle both REST (for admin/app control) and WebSocket (for real-time audio relay) on the same process."}],"\n",["$","li",null,{"children":"Data model is known and stable — 6 tables defined before any code was written."}],"\n",["$","li",null,{"children":["We need direct, predictable control over the database schema because key management depends on specific column semantics (",["$","code",null,{"children":"master_secret"}],", ",["$","code",null,{"children":"rotation_counter"}],")."]}],"\n",["$","li",null,{"children":"The droplet has 4 GB RAM and we're deploying via Docker Compose. No managed infrastructure budget."}],"\n"]}]
e:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"alternatives-considered","children":[["$","a",null,{"data-card":"","href":"#alternatives-considered","className":"peer","children":"Alternatives Considered"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
f:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Option"}],["$","th",null,{"children":"Why We Didn't Choose It"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Supabase"}]}],["$","td",null,{"children":"Adds vendor lock-in, requires their client SDK, uses Row Level Security policies instead of application-level auth. We started with it, ran into friction migrating auth, and cut it before the first working endpoint. Prisma + self-hosted Postgres gives us identical capability with no lock-in."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Express"}]}],["$","td",null,{"children":["Fastify is faster, has native TypeScript support, and its plugin system (",["$","code",null,{"children":"@fastify/jwt"}],", ",["$","code",null,{"children":"@fastify/websocket"}],") is cleaner than Express middleware for our use case. No meaningful reason to choose Express."]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"NestJS"}]}],["$","td",null,{"children":"Too much boilerplate for a one-week build. Decorator-heavy patterns slow down iteration."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"GraphQL"}]}],["$","td",null,{"children":"Our data access patterns are simple and well-defined (auth, talkgroup CRUD, device status, key fetch). GraphQL solves a flexibility problem we don't have, and adds resolver complexity we don't need."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Managed DB (RDS, Supabase, Neon)"}]}],["$","td",null,{"children":"Per-byte satellite traffic and constrained budget meant no managed database cost. Self-hosted Postgres in the same Docker Compose stack eliminates network latency between server and DB."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Redis for ephemeral state"}]}],["$","td",null,{"children":"In-memory Node.js Maps and Sets are sufficient for v1. Sessions re-establish on reconnect. Adding Redis is a single-line config change when needed."}]]}]]}]]}]}]
10:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-fastify--prisma--self-hosted-postgres","children":[["$","a",null,{"data-card":"","href":"#why-fastify--prisma--self-hosted-postgres","className":"peer","children":"Why Fastify + Prisma + Self-Hosted Postgres"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
11:["$","p",null,{"children":[["$","strong",null,{"children":"Fastify:"}]," Handles both REST and WebSocket on one process via ",["$","code",null,{"children":"@fastify/websocket"}],". Plugin-based architecture (",["$","code",null,{"children":"onRequest"}]," hooks for JWT auth) is clean and testable. Schema validation via JSON Schema is built in. Outperforms Express significantly under load."]}]
12:["$","p",null,{"children":[["$","strong",null,{"children":"Prisma:"}]," Generates a TypeScript client from a schema file. Queries are type-safe at compile time. Migrations are visible, version-controlled files. The schema is the documentation. Alternative ORMs (Sequelize, TypeORM) have heavier runtime overhead and worse TypeScript integration."]}]
13:["$","p",null,{"children":[["$","strong",null,{"children":"Self-hosted Postgres 16:"}]," Full control over schema, no row-level security complexity, co-located with the server in Docker Compose (sub-millisecond query latency), zero vendor dependency. ",["$","code",null,{"children":"prisma db push"}]," syncs schema to the live database on every container start — no migration runner needed for v1."]}]
14:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"tradeoffs-we-accepted","children":[["$","a",null,{"data-card":"","href":"#tradeoffs-we-accepted","className":"peer","children":"Tradeoffs We Accepted"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
15:["$","p",null,{"children":[["$","strong",null,{"children":"No Redis:"}]," In-memory Maps are lost on server restart. Clients reconnect and re-establish rooms. For PTT, a brief reconnect window is acceptable. If the server restarts mid-transmission, the audio is lost — same as a dropped satellite link."]}]
16:["$","p",null,{"children":[["$","strong",null,{"children":"Single-process, single-droplet:"}]," No horizontal scaling. One server handles all relay. For hackathon scope (a few concurrent users over satellite) this is fine. DigitalOcean allows vertical scaling without config changes."]}]
17:["$","p",null,{"children":[["$","strong",null,{"children":"JWT with no expiry in v1:"}]," We issue JWTs without short expiry during development to avoid re-login friction. Production requires ",["$","code",null,{"children":"exp"}]," to be set."]}]
