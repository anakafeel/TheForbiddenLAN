5a:["$","p",null,{"children":["The portal is a ",["$","strong",null,{"children":"utility interface"}]," used by operators at a desk, not under flight stress. Different constraints than the mobile app:"]}]
5b:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Density over minimalism"}]," — tables with many columns are appropriate here."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Confirmation dialogs"}]," for destructive actions (delete talkgroup, rotate key, disable device)."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"No realtime requirement"}]," — polling and page refreshes are acceptable for admin operations."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Standard web patterns"}]," — breadcrumb navigation, table pagination, form validation, toast notifications for success/error."]}],"\n"]}]
