{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/mobile/src",
  "projectType": "application",
  "tags": ["scope:mobile"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo start",
        "cwd": "packages/mobile"
      }
    },
    "android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo start --android",
        "cwd": "packages/mobile"
      }
    },
    "ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "expo start --ios",
        "cwd": "packages/mobile"
      }
    },
    "export": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "expo export --platform all",
        "cwd": "packages/mobile"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["packages/mobile/**/*.{ts,tsx,jsx}"] }
    }
  }
}
