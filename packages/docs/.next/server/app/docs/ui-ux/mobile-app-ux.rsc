46:["$","p",null,{"children":["The text message view is one level below the primary screen, accessible via the ",["$","code",null,{"children":"[≡ Text]"}]," button. It shows a scrollable message history for the current talkgroup and a text input field."]}]
47:["$","p",null,{"children":"Messages are fan-out only — there is no persistence in v1. Messages sent before you joined are not replayed."}]
