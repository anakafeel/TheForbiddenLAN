34:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-this-is-correct","children":[["$","a",null,{"data-card":"","href":"#why-this-is-correct","className":"peer","children":"Why This Is Correct"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
35:["$","p",null,{"children":["The algorithm is ",["$","strong",null,{"children":"deterministic and stateless"}],". Given the same set of ",["$","code",null,{"children":"PTT_START"}]," messages, every receiver — regardless of location, packet timing, or network conditions — reaches the ",["$","strong",null,{"children":"same winner"}],". No coordination is needed. No server message is required."]}]
36:["$","p",null,{"children":"All receivers see the same messages because the relay fans them all out. The algorithm runs identically on every device. Consensus emerges without a consensus round."}]
37:["$","hr",null,{}]
38:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-gps-timestamps","children":[["$","a",null,{"data-card":"","href":"#why-gps-timestamps","className":"peer","children":"Why GPS Timestamps"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
39:["$","p",null,{"children":"The DLS-140 provides GNSS timestamps that are:"}]
3a:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Globally synchronized"}]," — GPS atomic clocks agree across all aircraft"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Nanosecond resolution"}]," — far finer than the 50 ms collision window"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Available on every device"}]," that has a DLS-140 on its local LAN"]}],"\n"]}]
3b:["$","p",null,{"children":["Clock skew between sites is negligible compared to satellite latency. The ",["$","code",null,{"children":"SYNC_TIME"}]," mechanism in the comms library provides a software offset correction for devices not yet locked to GPS."]}]
3c:["$","hr",null,{}]
3d:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"the-50-ms-collision-window","children":[["$","a",null,{"data-card":"","href":"#the-50-ms-collision-window","className":"peer","children":"The 50 ms Collision Window"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
3e:["$","p",null,{"children":["We define a \"collision\" as two ",["$","code",null,{"children":"PTT_START"}]," messages arriving within 50 ms of each other. This window was chosen to be:"]}]
3f:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Small enough that the losing device stops quickly (wasted bandwidth is bounded)"}],"\n",["$","li",null,{"children":"Large enough to absorb realistic jitter on a local Wi-Fi hop"}],"\n"]}]
40:["$","p",null,{"children":"At 22 kbps with ~800 bps headroom, the cost of a brief collision is a few hundred bytes — acceptable."}]
41:["$","hr",null,{}]
42:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"accepted-tradeoffs","children":[["$","a",null,{"data-card":"","href":"#accepted-tradeoffs","className":"peer","children":"Accepted Tradeoffs"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
43:["$","p",null,{"children":[["$","strong",null,{"children":"We don't prevent collisions; we handle them."}]," There is a brief window where two senders transmit simultaneously before the loser's client resolves the collision. This wastes a small amount of satellite bandwidth. The benefit is instant PTT response."]}]
44:["$","p",null,{"children":[["$","strong",null,{"children":"Timestamp spoofing."}]," A compromised device could send a very old GPS timestamp to always win the floor. The operational mitigation is admin disabling the device via the portal. A cryptographic fix (signed timestamps) is v2."]}]
45:["$","p",null,{"children":[["$","strong",null,{"children":"Server doesn't enforce floor on audio."}]," In v1, the server relays all ",["$","code",null,{"children":"PTT_AUDIO"}]," regardless of who holds the floor. Floor state is client-maintained only. A misbehaving client can continue transmitting after losing arbitration. Server-side enforcement is a Phase 2 item."]}]
