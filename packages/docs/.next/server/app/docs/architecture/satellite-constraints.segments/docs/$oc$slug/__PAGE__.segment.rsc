21:["$","p",null,{"children":[["$","strong",null,{"children":[["$","code",null,{"children":"sessionId"}]," compression:"]}]," PTT audio chunks do not carry the sender's UUID (36 chars = 288 bits per chunk). Instead, a random 4-byte integer ",["$","code",null,{"children":"sessionId"}]," is generated at ",["$","code",null,{"children":"PTT_START"}],". The server maps ",["$","code",null,{"children":"sessionId → talkgroup"}]," for routing. Saves ~30 bytes per chunk, ~400 bps over a 20ms frame rate."]}]
22:["$","p",null,{"children":[["$","strong",null,{"children":"Field stripping on PTT_AUDIO:"}]," ",["$","code",null,{"children":"talkgroup"}],", ",["$","code",null,{"children":"timestamp"}],", and ",["$","code",null,{"children":"seq"}]," are not sent on every audio chunk. Those fields alone would add ~56 bytes/packet (9,333 bps at 16.7 fps). The server routes by ",["$","code",null,{"children":"sessionId"}]," instead."]}]
23:["$","p",null,{"children":[["$","strong",null,{"children":"Half-duplex enforcement:"}]," The comms library drops incoming ",["$","code",null,{"children":"PTT_AUDIO"}]," while the microphone is open. This prevents the uplink from carrying both transmitted and received audio simultaneously, which would saturate it."]}]
24:["$","h3",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"future-path-phase-2","children":[["$","a",null,{"data-card":"","href":"#future-path-phase-2","className":"peer","children":"Future path (Phase 2)"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
25:["$","p",null,{"children":"Switching PTT audio from WebSocket (TCP) to UDP/RTP removes all TCP framing overhead (~400 B/s) and eliminates TCP head-of-line blocking. Binary frame format (1B type + 4B sessionId + 3B chunk + raw Opus + 28B AES tag = ~96 B/frame) would reduce audio stream to ~12.8 kbps, giving 9.2 kbps of headroom."}]
26:["$","hr",null,{}]
27:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"latency-implications","children":[["$","a",null,{"data-card":"","href":"#latency-implications","className":"peer","children":"Latency Implications"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
28:["$","p",null,{"children":["The 500–1500 ms one-way latency is the reason floor control cannot involve a server round trip. A server-issued ",["$","code",null,{"children":"FLOOR_GRANT"}]," at minimum adds one full RTT (1–3 s) before a user can speak. Professional PTT systems (TETRA, DMR) do not work this way, and neither does SkyTalk."]}]
29:["$","p",null,{"children":["See ",["$","$L38",null,{"href":"/docs/architecture/floor-control","children":"Floor Control →"}]," for how we handle arbitration without adding round-trip latency."]}]
2a:["$","p",null,{"children":"The same latency makes TCP-based audio problematic: a single lost packet at 1500 ms RTT causes a ~3 second stall while TCP retransmits. TCP head-of-line blocking is a known issue in v1; the Phase 2 UDP roadmap addresses it."}]
