34:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Event"}],["$","th",null,{"children":"Action"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":["$","code",null,{"children":"onPressIn"}]}],["$","td",null,{"children":["Begin PTT session — sends ",["$","code",null,{"children":"PTT_START"}]," over WebSocket, acquires floor locally, starts Opus encode pipeline"]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","code",null,{"children":"onPressOut"}]}],["$","td",null,{"children":["End PTT session — sends ",["$","code",null,{"children":"PTT_END"}],", releases floor, stops encode pipeline"]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"Long press (>10 s)"}],["$","td",null,{"children":"Same as normal press — no timeout cutoff in v1"}]]}]]}]]}]}]
35:["$","p",null,{"children":["The app does ",["$","strong",null,{"children":"not"}]," use ",["$","code",null,{"children":"onPress"}]," (tap gesture). Transmission starts on touch-down, not touch-up, matching physical radio handset behaviour."]}]
