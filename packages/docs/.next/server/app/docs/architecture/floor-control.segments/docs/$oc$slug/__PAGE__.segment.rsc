17:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-this-is-correct","children":[["$","a",null,{"data-card":"","href":"#why-this-is-correct","className":"peer","children":"Why This Is Correct"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
18:["$","p",null,{"children":["The algorithm is ",["$","strong",null,{"children":"deterministic and stateless"}],". Given the same set of ",["$","code",null,{"children":"PTT_START"}]," messages, every receiver — regardless of location, packet timing, or network conditions — reaches the ",["$","strong",null,{"children":"same winner"}],". No coordination is needed. No server message is required."]}]
19:["$","p",null,{"children":"All receivers see the same messages because the relay fans them all out. The algorithm runs identically on every device. Consensus emerges without a consensus round."}]
1a:["$","hr",null,{}]
1b:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-gps-timestamps","children":[["$","a",null,{"data-card":"","href":"#why-gps-timestamps","className":"peer","children":"Why GPS Timestamps"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
1c:["$","p",null,{"children":"The DLS-140 provides GNSS timestamps that are:"}]
1d:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Globally synchronized"}]," — GPS atomic clocks agree across all aircraft"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Nanosecond resolution"}]," — far finer than the 50 ms collision window"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Available on every device"}]," that has a DLS-140 on its local LAN"]}],"\n"]}]
1e:["$","p",null,{"children":["Clock skew between sites is negligible compared to satellite latency. The ",["$","code",null,{"children":"SYNC_TIME"}]," mechanism in the comms library provides a software offset correction for devices not yet locked to GPS."]}]
