# SkyTalk mobile — environment variable reference.
#
# Copy to .env.local (gitignored) and fill in real values for Shri's backend.
# See BACKEND_INTEGRATION.md for the full step-by-step switchover guide.

# ── Core switch ───────────────────────────────────────────────────────────────
# true  = MockRelaySocket, no backend, loopback audio for testing
# false = real WebSocket to Shri's relay server
VITE_MOCK_MODE=true

# ── Shri's backend URLs (only needed when MOCK_MODE=false) ───────────────────
VITE_WS_URL=ws://localhost:9999          # → ws://<shri-server>:<port>
VITE_API_URL=http://localhost:3000       # → http://<shri-server>:<port>

# ── DLS-140 hardware URL (set when device is on same LAN) ────────────────────
VITE_DLS140_URL=http://192.168.111.1:3000

# ── Identity ──────────────────────────────────────────────────────────────────
VITE_TALKGROUP=alpha                     # talkgroup to join on connect
# VITE_DEVICE_ID=                        # leave blank = auto-stable UUID per browser

# ── Mock-only (ignored when MOCK_MODE=false) ──────────────────────────────────
VITE_MOCK_JWT=fake-jwt
