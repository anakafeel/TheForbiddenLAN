2e:["$","p",null,{"children":["In v1, the app connects to a single talkgroup at startup (configured via ",["$","code",null,{"children":"EXPO_PUBLIC_TALKGROUP"}]," env var or set at login). Multi-talkgroup switching is a v2 feature."]}]
2f:["$","p",null,{"children":["The talkgroup name is shown at the top of the primary screen at all times. If the WebSocket connection drops and reconnects, the app automatically re-issues ",["$","code",null,{"children":"JOIN_TALKGROUP"}]," for the current talkgroup."]}]
