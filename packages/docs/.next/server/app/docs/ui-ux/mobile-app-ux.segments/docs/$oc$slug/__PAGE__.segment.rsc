1c:["$","p",null,{"children":["The PTT button meets and exceeds Apple HIG's minimum interactive target size (44×44 pt). The current implementation uses a diameter of ",["$","strong",null,{"children":"120 pt"}]," centred on screen."]}]
1d:["$","p",null,{"children":"This is intentional:"}]
