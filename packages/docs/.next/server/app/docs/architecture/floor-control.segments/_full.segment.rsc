48:["$","p",null,{"children":["The ",["$","code",null,{"children":"FloorControl.ts"}]," module in ",["$","code",null,{"children":"packages/comms"}]," implements the timestamp comparison algorithm. It runs on every received ",["$","code",null,{"children":"PTT_START"}]," message. The relay server (",["$","code",null,{"children":"packages/server"}],") never imports ",["$","code",null,{"children":"FloorControl.ts"}]," — arbitration is purely client-side."]}]
