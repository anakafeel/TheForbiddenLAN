2b:["$","li",null,{"children":"22 kbps uplink is tight. Protocol overhead matters — every header byte counts."}]
2c:["$","li",null,{"children":"One week to implement. The transport must ship, not be perfect."}]
2d:["$","li",null,{"children":"The server performs fan-out relay only — no audio processing. The transport must be server-agnostic to audio content."}]
2e:["$","li",null,{"children":"TCP head-of-line blocking at 1500 ms RTT causes multi-second audio freezes on packet loss. This is a known problem, not an oversight."}]
2f:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"alternatives-considered","children":[["$","a",null,{"data-card":"","href":"#alternatives-considered","className":"peer","children":"Alternatives Considered"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
30:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Option"}],["$","th",null,{"children":"Why We Didn't Choose It"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"MQTT"}]}],["$","td",null,{"children":"Designed for low-bandwidth IoT telemetry, not real-time audio. Message ordering and QoS overhead adds latency. Broker-based architecture adds another service to deploy."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"WebRTC"}]}],["$","td",null,{"children":"Requires ICE/STUN/TURN for NAT traversal. The DLS-140 is behind Iridium's carrier-grade NAT — STUN fails, TURN is required. TURN adds relay overhead on top of our relay. WebRTC peer negotiation requires multiple RTTs to establish — at 1500 ms each, setup takes 3–10 seconds. SDP signaling is complex for a relay architecture."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"HTTP polling"}]}],["$","td",null,{"children":"Per-request overhead at 500–1500 ms latency means polling at useful rate (~5 Hz) would consume the entire uplink budget for control traffic before any audio."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"HTTP/2 server push"}]}],["$","td",null,{"children":"One-directional from server to client. Clients cannot push audio to the server over server push — it's a downlink-only mechanism."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Raw TCP socket"}]}],["$","td",null,{"children":"WebSocket is TCP with a standardized framing layer and HTTP upgrade handshake. No meaningful benefit to dropping the WebSocket layer, and it breaks browser compatibility."}]]}]]}]]}]}]
31:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-websocket-for-v1","children":[["$","a",null,{"data-card":"","href":"#why-websocket-for-v1","className":"peer","children":"Why WebSocket for v1"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
32:["$","p",null,{"children":[["$","strong",null,{"children":"Single persistent connection"}]," — no per-message handshake overhead. At 500–1500 ms latency, a new connection per audio chunk would add seconds of setup per transmission."]}]
33:["$","p",null,{"children":[["$","strong",null,{"children":"Bidirectional"}]," — client pushes audio, server fans out audio, control messages flow both ways on the same socket."]}]
34:["$","p",null,{"children":[["$","strong",null,{"children":"Ships in one week"}]," — every Node.js framework has first-class WebSocket support. ",["$","code",null,{"children":"@fastify/websocket"}]," adds WebSocket to our existing Fastify server with no additional infrastructure."]}]
35:["$","p",null,{"children":[["$","strong",null,{"children":"Sufficient for demo"}]," — TCP reliability means we don't need application-layer retransmission logic for the hackathon scope."]}]
36:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-websocket-is-wrong-for-audio-long-term","children":[["$","a",null,{"data-card":"","href":"#why-websocket-is-wrong-for-audio-long-term","className":"peer","children":"Why WebSocket Is Wrong for Audio Long-Term"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
37:["$","p",null,{"children":"TCP provides guaranteed ordered delivery. It achieves this by retransmitting lost packets and stalling the receiver until they arrive (head-of-line blocking)."}]
38:["$","p",null,{"children":"At 1500 ms satellite RTT:"}]
39:["$","ul",null,{"children":["\n",["$","li",null,{"children":"One lost audio packet → server retransmits"}],"\n",["$","li",null,{"children":"Client waits ~1500 ms for retransmission"}],"\n",["$","li",null,{"children":"Audio buffer empties → ~3 seconds of silence"}],"\n",["$","li",null,{"children":"This happens on every satellite handoff dropout (~every 8 minutes)"}],"\n"]}]
3a:["$","p",null,{"children":"A dropped voice frame in PTT causes a brief click. A 3-second stall destroys intelligibility. The tradeoff is wrong."}]
3b:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"phase-2-udprtp-for-audio","children":[["$","a",null,{"data-card":"","href":"#phase-2-udprtp-for-audio","className":"peer","children":"Phase 2: UDP/RTP for Audio"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
3c:["$","p",null,{"children":"The correct solution is well-established in professional PTT (TETRA, ISSI, P25):"}]
3d:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Plane"}],["$","th",null,{"children":"v1"}],["$","th",null,{"children":"v2"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":"Control (PTT_START, PRESENCE, TEXT)"}],["$","td",null,{"children":"WebSocket (TCP)"}],["$","td",null,{"children":"WebSocket (TCP)"}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"Audio chunks (PTT_AUDIO)"}],["$","td",null,{"children":"WebSocket (TCP)"}],["$","td",null,{"children":"UDP/RTP"}]]}]]}]]}]}]
3e:["$","p",null,{"children":"UDP drops frames without stalling. A dropped voice frame causes a brief click. The jitter buffer (50–200 ms) on the receiver absorbs burst packet timing. The listening experience on a lossy satellite link is fundamentally better."}]
3f:["$","p",null,{"children":[["$","strong",null,{"children":"Why not v1?"}]," UDP requires a separate socket, a custom RTP framing implementation, and a jitter buffer — a full additional subsystem. The server relay logic needs to handle both protocols. At one week, we ship WebSocket and document the upgrade path."]}]
