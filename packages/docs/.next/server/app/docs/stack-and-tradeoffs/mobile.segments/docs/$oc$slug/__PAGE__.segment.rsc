10:["$","p",null,{"children":[["$","strong",null,{"children":"Shared codebase."}]," The same screen and component files target browser, Android, and iOS. Three build targets from one source:"]}]
11:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Target"}],["$","th",null,{"children":"Build tool"}],["$","th",null,{"children":"Command"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":"Browser (dev/testing)"}],["$","td",null,{"children":"Vite + react-native-web"}],["$","td",null,{"children":["$","code",null,{"children":"pnpm dev:mobile"}]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"Android"}],["$","td",null,{"children":"Metro + Gradle"}],["$","td",null,{"children":["$","code",null,{"children":"pnpm android"}]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":"iOS"}],["$","td",null,{"children":"Metro + Xcode"}],["$","td",null,{"children":"(excluded this phase)"}]]}]]}]]}]}]
12:["$","p",null,{"children":[["$","strong",null,{"children":"react-native-web"}]," re-implements every React Native primitive as a DOM equivalent (",["$","code",null,{"children":"View"}]," → ",["$","code",null,{"children":"<div>"}],", ",["$","code",null,{"children":"Text"}]," → ",["$","code",null,{"children":"<span>"}],", ",["$","code",null,{"children":"StyleSheet"}]," → CSS-in-JS). Vite redirects ",["$","code",null,{"children":"react-native"}]," imports to ",["$","code",null,{"children":"react-native-web"}]," at bundle time. The full PTT loop can be developed and tested in a browser with no device needed."]}]
13:["$","p",null,{"children":[["$","strong",null,{"children":"Expo SDK 54"}]," abstracts platform differences for permissions, audio session management, file system access, and secure storage. The dev build allows custom native modules."]}]
14:["$","p",null,{"children":[["$","strong",null,{"children":"TypeScript throughout."}]," ",["$","code",null,{"children":"packages/comms"}]," exports typed interfaces that the mobile app imports directly without a code generation step. Floor control types, audio chunk types, and WebSocket message types are shared at compile time."]}]
15:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-ios-was-dropped-this-phase","children":[["$","a",null,{"data-card":"","href":"#why-ios-was-dropped-this-phase","className":"peer","children":"Why iOS Was Dropped This Phase"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
16:["$","p",null,{"children":"Compiling a custom Expo Dev Build for iOS requires macOS and Xcode. Our primary dev environment is Fedora Linux. EAS Cloud (remote build service) is available but adds build queue latency and requires an Apple Developer account."}]
17:["$","p",null,{"children":["The decision: develop and demo on Android, document iOS as a post-hackathon enable. The ",["$","code",null,{"children":"packages/mobile"}]," code is platform-agnostic; re-enabling iOS requires setting up Xcode, adding the iOS EAS build profile, and testing ",["$","code",null,{"children":"react-native-audio-recorder-player"}]," on iOS — no code changes."]}]
18:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"tradeoffs-we-accepted","children":[["$","a",null,{"data-card":"","href":"#tradeoffs-we-accepted","className":"peer","children":"Tradeoffs We Accepted"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
19:["$","p",null,{"children":[["$","strong",null,{"children":"Audio is whole-file-per-press in current implementation."}]," Ideal PTT sends 60 ms chunks as the user speaks (streaming pipeline). Current implementation records to a file, then reads the file on PTT release. This means no audio is heard until the user releases the button. Streaming requires ",["$","code",null,{"children":"react-native-live-audio-stream"}]," + an EAS build with native modules compiled in — committed to the roadmap."]}]
1a:["$","p",null,{"children":[["$","strong",null,{"children":"Pass-through crypto for mock mode."}]," The Web Crypto API (",["$","code",null,{"children":"crypto.subtle"}],") is unavailable in Hermes (React Native's JS engine). A pass-through polyfill (",["$","code",null,{"children":"packages/mobile/src/shims/setup-crypto.js"}],") mimics the interface but performs no encryption. This is acceptable for local mock testing; production requires replacing it with ",["$","code",null,{"children":"@noble/ciphers"}]," or ",["$","code",null,{"children":"react-native-quick-crypto"}],"."]}]
1b:["$","p",null,{"children":[["$","strong",null,{"children":"Two App entry points."}]," ",["$","code",null,{"children":"App.jsx"}]," (native, uses React Navigation) and ",["$","code",null,{"children":"App.web.jsx"}]," (browser, uses manual state navigation — React Navigation's native modules don't exist in a browser). This adds a small maintenance surface."]}]
1c:["$","p",null,{"children":[["$","strong",null,{"children":"pnpm + Metro symlink resolution."}]," pnpm's virtual store uses symlinks that Metro doesn't follow by default. We enable ",["$","code",null,{"children":"unstable_enableSymlinks"}]," and add workspace ",["$","code",null,{"children":"node_modules"}]," to ",["$","code",null,{"children":"watchFolders"}],". Adds ~2–3 seconds to Metro cold start and increases memory usage by ~200 MB. The alternative (switching to npm/yarn flat ",["$","code",null,{"children":"node_modules"}],") loses pnpm's 2–3x install speed advantages and disk savings across the monorepo."]}]
