30:["$","p",null,{"children":["The PTT button meets and exceeds Apple HIG's minimum interactive target size (44×44 pt). The current implementation uses a diameter of ",["$","strong",null,{"children":"120 pt"}]," centred on screen."]}]
31:["$","p",null,{"children":"This is intentional:"}]
32:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Gloved hands can hit a 120 pt circle reliably."}],"\n",["$","li",null,{"children":"The button occupies the natural thumb zone when the phone is held one-handed."}],"\n",["$","li",null,{"children":"It is impossible to miss on a glance."}],"\n"]}]
