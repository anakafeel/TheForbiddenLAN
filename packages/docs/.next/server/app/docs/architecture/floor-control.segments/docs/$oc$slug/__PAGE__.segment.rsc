#24292E","--shiki-dark":"#E1E4E8"},"children":"    B->>Server: PTT_START {talkgroup, sender, timestamp: T_B, seq: 1}"}]}],"\n",["$","span",null,{"className":"line","children":" "}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Server->>A: PTT_START from B (fan-out)"}]}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Server->>B: PTT_START from A (fan-out)"}]}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Server->>C: PTT_START from A (fan-out)"}]}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Server->>C: PTT_START from B (fan-out)"}]}],"\n",["$","span",null,{"className":"line","children":" "}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Note over A,C: Each client independently runs arbitration:<br/>if T_A < T_B → A wins<br/>if within 50ms → compare UUIDs"}]}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Note over A: A continues transmitting"}]}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Note over B: B sees T_A < T_B, stops transmitting"}]}],"\n",["$","span",null,{"className":"line","children":["$","span",null,{"style":{"--shiki-light":"#24292E","--shiki-dark":"#E1E4E8"},"children":"    Note over C: C receives audio from A only"}]}]]}]}]
14:["$","h3",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"step-by-step","children":[["$","a",null,{"data-card":"","href":"#step-by-step","className":"peer","children":"Step-by-step"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
15:["$","ol",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"User presses PTT."}]," The phone immediately begins capturing and transmitting audio. No permission requested."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":[["$","code",null,{"children":"PTT_START"}]," is sent."]}]," Carries GPS timestamp (from DLS-140 GNSS) and device UUID."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Relay fans it out."}]," Server fans ",["$","code",null,{"children":"PTT_START"}]," to all talkgroup members. Server applies no logic."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Each receiver runs arbitration independently:"}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":["If one ",["$","code",null,{"children":"PTT_START"}]," arrived: that sender has the floor."]}],"\n",["$","li",null,{"children":["If two ",["$","code",null,{"children":"PTT_START"}]," messages arrive within a ",["$","strong",null,{"children":"50 ms window"}]," (collision): lower GPS timestamp wins. Tiebreaker: lexicographically smaller device UUID."]}],"\n"]}],"\n"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Loser stops."}]," The losing device's UI shows \"floor taken\". It stops transmitting."]}],"\n"]}]
