9",null,{"className":"max-w-[860px]","children":[["$","$La",null,{}],[["$","h1",null,{"children":"Infrastructure","className":"text-3xl font-bold"}],["$","p",null,{"children":"Why DigitalOcean + Docker Compose — and why we ruled out Kubernetes, managed databases, serverless, and multi-region deployments.","className":"mb-8 text-lg text-fd-muted-foreground"}],["$","div",null,{"children":[["$","h1",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"infrastructure","children":[["$","a",null,{"data-card":"","href":"#infrastructure","className":"peer","children":"Infrastructure"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}],"\n",["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"decision","children":[["$","a",null,{"data-card":"","href":"#decision","className":"peer","children":"Decision"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"A single DigitalOcean droplet"}]," (Ubuntu, 2 vCPU, 4 GB RAM) running Docker Compose with two services: Postgres 16 and the Node.js relay server. No Kubernetes, no managed database, no CDN."]}],"\n",["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"constraints-that-drove-this","children":["$Lb","$Lc"]}],"\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c"],"className":"prose"}]],"$L1d","$L1e","$L1f"]}]]}],"$L20"]}],["$L21","$L22"],"$L23"]}],"loading":null,"isPartial":false}
