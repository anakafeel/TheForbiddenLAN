40:["$","p",null,{"children":["Total per-chunk overhead: 28 bytes. At 6 kbps Opus with 60 ms frames (16.7 fps): ",["$","strong",null,{"children":"467 bytes/sec = 3,733 bps"}]," — 17% of the uplink budget."]}]
