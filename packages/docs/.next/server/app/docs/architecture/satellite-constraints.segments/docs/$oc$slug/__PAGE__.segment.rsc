d:["$","p",null,{"children":["Each aircraft runs a SKYTRAC DLS-140 satellite router. Phones on board connect to it over Wi-Fi on a private ",["$","code",null,{"children":"192.168.111.0/24"}]," LAN. The DLS-140 routes outbound traffic over Iridium Certus."]}]
e:["$","p",null,{"children":[["$","strong",null,{"children":"The critical constraint:"}]," the DLS-140 is outbound-only. It can open connections to the internet. It cannot accept inbound connections. The Iridium network assigns addresses via PPP and sits behind carrier-grade NAT. Even if the DLS-140 exposed port-forwarding (it does not in current firmware), Iridium's network-level NAT would block packets from reaching it. ",["$","strong",null,{"children":"There is no path from the internet to a DLS-140."}]]}]
f:["$","p",null,{"children":"This makes peer-to-peer DLS-140 communication impossible. Unit A cannot dial Unit B. Both must connect outbound to a relay server — architecture follows from hardware."}]
10:["$","hr",null,{}]
