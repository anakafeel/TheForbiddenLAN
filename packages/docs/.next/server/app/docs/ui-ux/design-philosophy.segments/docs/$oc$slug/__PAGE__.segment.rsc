1b:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"one-tap-ptt","children":[["$","a",null,{"data-card":"","href":"#one-tap-ptt","className":"peer","children":"One-Tap PTT"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
1c:["$","p",null,{"children":["The PTT interaction is designed around a single constraint: ",["$","strong",null,{"children":"the user must be able to initiate a transmission with one thumb, without looking at the screen"}],"."]}]
1d:["$","p",null,{"children":"This means:"}]
1e:["$","ul",null,{"children":["\n",["$","li",null,{"children":["The PTT button is ",["$","strong",null,{"children":"centred and large"}]," — target area exceeds Apple's recommended minimum of 44×44 pt by a wide margin (see ",["$","$L32",null,{"href":"/docs/ui-ux/mobile-app-ux","children":"Mobile App UX →"}],")."]}],"\n",["$","li",null,{"children":["The button uses ",["$","strong",null,{"children":"touch-down / touch-up"}]," events, not tap. Speech starts on press, not on release. This is how every radio handset in the world works."]}],"\n",["$","li",null,{"children":"Visual and (optionally) haptic feedback confirm floor acquisition."}],"\n"]}]
1f:["$","hr",null,{}]
20:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"cognitive-load-budget","children":[["$","a",null,{"data-card":"","href":"#cognitive-load-budget","className":"peer","children":"Cognitive Load Budget"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
21:["$","p",null,{"children":"Aircrew are operating in high-workload environments. SkyTalk assumes the user can spare:"}]
22:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"~100 ms of attention"}]," to find the PTT button."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"~0 ms of attention"}]," to interpret the floor state — it must be glanceable."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"0 deliberate steps"}]," to switch from listening to transmitting."]}],"\n"]}]
23:["$","p",null,{"children":"This is why features like push notifications, settings links, and admin controls are absent from the primary screen. The app boots directly to the active talkgroup with the PTT button ready."}]
24:["$","hr",null,{}]
25:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"satellite-latency-and-perceived-responsiveness","children":[["$","a",null,{"data-card":"","href":"#satellite-latency-and-perceived-responsiveness","className":"peer","children":"Satellite Latency and Perceived Responsiveness"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
26:["$","p",null,{"children":"Over Iridium Certus, round-trip time is 500–1500 ms. Users will hear audio from the other end with this delay. The UI should not amplify this uncertainty."}]
27:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Floor grant is local and instant."}]," The app immediately shows \"you have the floor\" when PTT is pressed, without waiting for a server acknowledgment. The ",["$","$L32",null,{"href":"/docs/architecture/floor-control","children":"floor arbitration algorithm"}]," is deterministic — every device reaches the same outcome independently, so there is no server round trip."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Latency is expected, not an error."}]," The app does not show a loading spinner or \"connecting…\" state during the transmission delay — this is normal radio behaviour."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Disconnection vs high latency is distinguished."}]," A WebSocket drop shows a clear \"offline\" indicator. Slow audio is not treated as an error."]}],"\n"]}]
