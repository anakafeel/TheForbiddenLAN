# SkyTalk mobile — environment variable reference.
#
# Copy to .env (or .env.local) and fill in real values.
# See docs/BACKEND_INTEGRATION.md for the full step-by-step guide.

# ── Relay server URLs ─────────────────────────────────────────────────────────
EXPO_PUBLIC_WS_URL=ws://134.122.32.45:3000/ws
EXPO_PUBLIC_API_URL=http://134.122.32.45:3000

# ── DLS-140 hardware URL (set when device is on same LAN as the terminal) ────
EXPO_PUBLIC_DLS140_URL=http://192.168.111.1:3000
EXPO_PUBLIC_DLS140_USER=skytrac
EXPO_PUBLIC_DLS140_PASS=skytrac

# ── Identity ──────────────────────────────────────────────────────────────────
EXPO_PUBLIC_TALKGROUP=alpha              # talkgroup to join on connect
# EXPO_PUBLIC_DEVICE_ID=                 # leave blank = auto UUID per install

# ── Loopback testing ──────────────────────────────────────────────────────────
# Echoes your TX audio back through the local decode→playback pipeline.
# Set to true for single-device testing, false for multi-device.
EXPO_PUBLIC_LOOPBACK=false
