1f:["$","p",null,{"children":[["$","strong",null,{"children":"Control plane — REST API"}],"\nSource of truth for auth, talkgroup membership, device registry, and key material. The admin portal is the UI for this. An ",["$","code",null,{"children":"admin"}],"-role user can provision devices, manage talkgroups, trigger key rotations, and enable/disable devices."]}]
20:["$","p",null,{"children":[["$","strong",null,{"children":"Data plane — WebSocket hub"}],"\nMaintains a room map: ",["$","code",null,{"children":"talkgroup → Set<WebSocket>"}],". Messages from any client are fanned out to all other clients in the same talkgroup. The server does not decode audio — it relays encrypted blobs. It does maintain in-memory state for presence and session routing."]}]
21:["$","p",null,{"children":["The server does ",["$","strong",null,{"children":"not"}],":"]}]
22:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Talk to DLS-140 hardware (that's the comms library's job)"}],"\n",["$","li",null,{"children":"Decode or process audio (moves encrypted blobs only)"}],"\n",["$","li",null,{"children":["Make floor control decisions (fans out ",["$","code",null,{"children":"PTT_START"}],", clients arbitrate)"]}],"\n",["$","li",null,{"children":["Generate or distribute AES keys (stores ",["$","code",null,{"children":"master_secret"}]," + ",["$","code",null,{"children":"rotation_counter"}],", clients derive keys via KDF)"]}],"\n"]}]
