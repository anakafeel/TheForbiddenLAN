2a:["$","ol",null,{"children":["\n",["$","li",null,{"children":["User presses PTT (",["$","code",null,{"children":"onPressIn"}],")."]}],"\n",["$","li",null,{"children":"App immediately shows \"TRANSMITTING\" — no waiting for server."}],"\n",["$","li",null,{"children":["App sends ",["$","code",null,{"children":"PTT_START"}]," to server, which fans it out."]}],"\n",["$","li",null,{"children":["If a competing ",["$","code",null,{"children":"PTT_START"}]," arrives within 50 ms (collision), the app runs arbitration:","\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"If the local device's GPS timestamp is lower → user keeps the floor, no UI change."}],"\n",["$","li",null,{"children":["If the remote device's GPS timestamp is lower → user loses the floor:","\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":"Button returns to grey."}],"\n",["$","li",null,{"children":"Status shows \"Channel busy — <other user>\"."}],"\n",["$","li",null,{"children":"Haptic double-tap fires."}],"\n",["$","li",null,{"children":"Audio encode pipeline stops."}],"\n"]}],"\n"]}],"\n"]}],"\n"]}],"\n"]}]
2b:["$","p",null,{"children":"The goal: the user is never left uncertain. They have the floor or they don't, and the UI reflects this within one animation frame."}]
