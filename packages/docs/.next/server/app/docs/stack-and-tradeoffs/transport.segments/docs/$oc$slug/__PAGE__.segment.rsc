:"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"WebSocket (TCP) for all traffic in v1."}]," Audio chunks and control messages (PTT_START, PRESENCE, TEXT_MSG) travel on the same persistent WebSocket connection. Phase 2 roadmap moves audio to UDP/RTP while keeping control on WebSocket."]}],"\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21"],"className":"prose"}]],"$L22","$L23","$L24"]}]]}],"$L25"]}],["$L26","$L27"],"$L28"]}],"loading":null,"isPartial":false}
