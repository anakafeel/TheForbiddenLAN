55:["$","ul",null,{"children":["\n",["$","li",null,{"children":["On load, fetches ",["$","code",null,{"children":"GET /devices"}]," to get all device IDs, then calls ",["$","code",null,{"children":"GET /devices/:id/gps"}]," for each."]}],"\n",["$","li",null,{"children":"Renders pins on a map tile layer (Leaflet.js with OpenStreetMap tiles)."}],"\n",["$","li",null,{"children":"Auto-refreshes every 30 seconds (no WebSocket subscription from the portal in v1)."}],"\n"]}]
56:["$","p",null,{"children":"Each pin shows: device name, site, last update timestamp."}]
