c:["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]
d:["$","ul",null,{"children":["\n",["$","li",null,{"children":"One week to deploy and have teammates' devices connecting over satellite."}],"\n",["$","li",null,{"children":"The relay server is stateful — WebSocket rooms live in memory. Horizontal scaling requires coordination (Redis pub/sub or sticky sessions). We don't need to scale to more than one instance for a hackathon."}],"\n",["$","li",null,{"children":["The Postgres database is co-located with the server. Sub-millisecond query latency on ",["$","code",null,{"children":"findUnique"}]," calls (JWT verification path) matters for WebSocket connection throughput."]}],"\n",["$","li",null,{"children":"Budget: DigitalOcean $24/month droplet is the entire infrastructure cost."}],"\n",["$","li",null,{"children":["The deployment workflow is: push to git → ssh → ",["$","code",null,{"children":"git pull"}]," → ",["$","code",null,{"children":"docker compose up --build -d"}],". This needs to work reliably without CI/CD."]}],"\n"]}]
e:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"alternatives-considered","children":[["$","a",null,{"data-card":"","href":"#alternatives-considered","className":"peer","children":"Alternatives Considered"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
f:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Option"}],["$","th",null,{"children":"Why We Didn't Choose It"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Kubernetes (GKE, EKS, AKS)"}]}],["$","td",null,{"children":"Multi-hour setup, requires understanding of Deployments, Services, Ingress, ConfigMaps, Secrets, PersistentVolumeClaims. Overkill for a single stateful service."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"AWS Elastic Beanstalk / App Runner"}]}],["$","td",null,{"children":"Higher cost, more config surface, harder to debug. We need direct ssh access and control over the exact Node.js version."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Serverless (Lambda, Cloud Run)"}]}],["$","td",null,{"children":"WebSocket requires a persistent server process. Serverless functions timeout after 15–30 seconds — incompatible with long-lived PTT sessions. Cold start latency at 500 ms satellite RTT is unacceptable."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Managed Postgres (RDS, Neon, Supabase)"}]}],["$","td",null,{"children":"Adds inter-service network latency (even within a region: 1–5 ms). More importantly, adds monthly cost and a separate connection string to manage. Self-hosted in Docker Compose on the same machine has ~0.1 ms query latency and zero additional cost."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Multi-region deployment"}]}],["$","td",null,{"children":"The relay is a single switchboard. All aircraft connect to one server. Multiple regions would require routing logic (which region is closest to the satellite ground station?) that adds complexity without benefit at hackathon scale."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"nginx reverse proxy + SSL (done, but deferred)"}]}],["$","td",null,{"children":["nginx config and Let's Encrypt cert are written and ready in ",["$","code",null,{"children":"packages/server/nginx/"}],". Deferred because the team uses the IP directly over HTTP during development, and SSL requires DNS propagation (up to an hour). Will be activated when the domain is pointed at the droplet."]}]]}]]}]]}]}]
10:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"why-digitalocean--docker-compose","children":[["$","a",null,{"data-card":"","href":"#why-digitalocean--docker-compose","className":"peer","children":"Why DigitalOcean + Docker Compose"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
11:["$","p",null,{"children":[["$","strong",null,{"children":"DigitalOcean droplets"}]," are predictable, fast to provision, and have a straightforward billing model. The Carleton team has prior experience with them. SSH access is immediate. No IAM policies, no VPC configuration, no security group rules — just a server with a public IP."]}]
12:["$","p",null,{"children":[["$","strong",null,{"children":"Docker Compose"}]," makes the two-service dependency (Postgres + server) declarative and reproducible. The ",["$","code",null,{"children":"depends_on"}]," with ",["$","code",null,{"children":"service_healthy"}]," ensures Postgres is ready before the server starts. ",["$","code",null,{"children":"prisma db push"}]," runs in the server container's ",["$","code",null,{"children":"entrypoint.sh"}]," on every start — schema is always in sync, no manual migration step. The entire server environment is reproducible from ",["$","code",null,{"children":"docker compose up --build"}],"."]}]
13:["$","p",null,{"children":[["$","strong",null,{"children":"Why not just run Node.js directly?"}]," Running in Docker means:"]}]
14:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Node.js version is pinned (node:20-alpine) and reproducible across environments"}],"\n",["$","li",null,{"children":"Postgres runs in isolation — no system-level Postgres install, no version conflicts"}],"\n",["$","li",null,{"children":"The entire stack can be torn down and rebuilt cleanly in < 2 minutes"}],"\n",["$","li",null,{"children":"Future teammates can reproduce the deployment by running one command"}],"\n"]}]
