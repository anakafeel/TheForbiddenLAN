# pnpm configuration for React Native / Expo monorepo
#
# WHY shamefully-hoist: Metro Bundler requires a flat node_modules structure
# (like npm). Without this, pnpm's strict virtual store means every transitive
# dependency (expo-asset, @babel/runtime, use-latest-callback, etc.) must be
# explicitly listed — which is not maintainable.
# This is the standard recommendation for Expo + pnpm.
# See: https://docs.expo.dev/guides/monorepos/#npm-workspaces
shamefully-hoist=true
