{
  "name": "comms",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/comms/src",
  "projectType": "library",
  "tags": ["scope:comms"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/comms",
        "main": "packages/comms/src/index.ts",
        "tsConfig": "packages/comms/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["packages/comms/**/*.ts"] }
    }
  }
}
