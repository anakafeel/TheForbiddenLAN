20:["$","ol",null,{"children":["\n",["$","li",null,{"children":["Admin sets ",["$","code",null,{"children":"active = false"}]," on the device record (",["$","code",null,{"children":"PATCH /devices/:id/status"}],")"]}],"\n",["$","li",null,{"children":["Admin triggers a key rotation (",["$","code",null,{"children":"POST /keys/rotate"}],")"]}],"\n",["$","li",null,{"children":"The revoked device's JWT expires (JWTs are short-lived)"}],"\n",["$","li",null,{"children":"Without a valid JWT, the device cannot re-authenticate"}],"\n",["$","li",null,{"children":["Without authentication, it cannot fetch the new ",["$","code",null,{"children":"rotation_counter"}]]}],"\n",["$","li",null,{"children":"Without the counter, it cannot derive the new group key"}],"\n",["$","li",null,{"children":"Audio encrypted with the new key is undecryptable to the revoked device"}],"\n"]}]
