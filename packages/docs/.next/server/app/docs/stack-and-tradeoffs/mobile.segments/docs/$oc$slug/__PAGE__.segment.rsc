c:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Two developers (Maisam + Annie) building a mobile app in one week."}],"\n",["$","li",null,{"children":"The app must run on Android devices physically attached to aircraft LANs."}],"\n",["$","li",null,{"children":["The comms library (",["$","code",null,{"children":"packages/comms"}],") is TypeScript. Mobile and comms must share types without a build step."]}],"\n",["$","li",null,{"children":"Need real native audio APIs — the Web Audio API is unavailable on the satellite hardware environment."}],"\n",["$","li",null,{"children":"Primary engineering environment is Linux (Carleton labs). iOS development requires macOS + Xcode."}],"\n"]}]
d:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"alternatives-considered","children":[["$","a",null,{"data-card":"","href":"#alternatives-considered","className":"peer","children":"Alternatives Considered"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
e:["$","div",null,{"className":"relative overflow-auto","children":["$","table",null,{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"children":"Option"}],["$","th",null,{"children":"Why We Didn't Choose It"}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Flutter"}]}],["$","td",null,{"children":["Different language (Dart). Team's expertise is JavaScript/TypeScript. Sharing typed interfaces with ",["$","code",null,{"children":"packages/comms"}]," (TypeScript) would require code generation."]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Capacitor (Web + native wrapper)"}]}],["$","td",null,{"children":["We started here. Capacitor wraps a WebView around a web app. ",["$","code",null,{"children":"MediaRecorder"}]," (browser) works for audio in the web view, but we needed 60ms chunk streaming with native codecs (Opus, Codec2). Native audio libraries (",["$","code",null,{"children":"react-native-live-audio-stream"}],", ",["$","code",null,{"children":"react-native-opus"}],") don't exist for Capacitor. Switched to React Native."]}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Native Android (Kotlin/Java)"}]}],["$","td",null,{"children":"No prior team experience. Cannot share comms library code. PTT UI would need to be built from scratch."}]]}],["$","tr",null,{"children":[["$","td",null,{"children":["$","strong",null,{"children":"Expo Go (managed workflow)"}]}],["$","td",null,{"children":["Expo Go ships a fixed set of pre-compiled native libraries. ",["$","code",null,{"children":"react-native-live-audio-stream"}]," and ",["$","code",null,{"children":"react-native-opus"}]," (custom C++ bindings) are not included. An Expo Development Build (EAS) is required."]}]]}]]}]]}]}]
