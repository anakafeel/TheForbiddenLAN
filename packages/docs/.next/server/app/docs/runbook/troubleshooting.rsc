4c:["$","$L2c",null,{"title":"PTT audio is not received by other clients","children":["$","ol",null,{"children":["\n",["$","li",null,{"children":["Confirm both clients sent ",["$","code",null,{"children":"JOIN_TALKGROUP"}]," for the ",["$","strong",null,{"children":"same"}]," talkgroup UUID."]}],"\n",["$","li",null,{"children":["Confirm ",["$","code",null,{"children":"PTT_START"}]," was sent before ",["$","code",null,{"children":"PTT_AUDIO"}]," — the server maps ",["$","code",null,{"children":"sessionId"}]," to a talkgroup at ",["$","code",null,{"children":"PTT_START"}]," time."]}],"\n",["$","li",null,{"children":["Check ",["$","code",null,{"children":"sessionId"}]," in ",["$","code",null,{"children":"PTT_AUDIO"}]," matches the value used in ",["$","code",null,{"children":"PTT_START"}],"."]}],"\n",["$","li",null,{"children":"Self-echo prevention: a sender does not receive its own audio. Use two separate WebSocket connections to test fan-out."}],"\n"]}]}]
4d:["$","$L2c",null,{"title":"PRESENCE not received after JOIN_TALKGROUP","children":["$","p",null,{"children":["Check server logs. If the talkgroup UUID doesn't exist in the database, the server still adds the socket to an in-memory room and sends PRESENCE — but the talkgroup won't appear in REST API responses. Create the talkgroup via ",["$","code",null,{"children":"POST /talkgroups"}]," first."]}]}]
