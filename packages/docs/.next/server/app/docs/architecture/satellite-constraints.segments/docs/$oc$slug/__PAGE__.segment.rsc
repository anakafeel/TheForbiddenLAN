19:["$","p",null,{"children":"The most important question: does our audio + encryption + framing stack fit in 22 kbps?"}]
1a:["$","p",null,{"children":["At ",["$","strong",null,{"children":"Opus 6 kbps, 60 ms frames"}]," (validated by ",["$","code",null,{"children":"test-opus-pipeline.ts"}],"):"]}]
