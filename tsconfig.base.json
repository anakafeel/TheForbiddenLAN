{
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@skytalk/comms": ["packages/comms/src/index.ts"],
      "@skytalk/comms/*": ["packages/comms/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
