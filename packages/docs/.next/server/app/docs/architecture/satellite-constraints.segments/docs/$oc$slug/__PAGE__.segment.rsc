2c:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"gps-and-the-dls-140","children":[["$","a",null,{"data-card":"","href":"#gps-and-the-dls-140","className":"peer","children":"GPS and the DLS-140"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
2d:["$","p",null,{"children":"The DLS-140 has a built-in GNSS receiver. GPS time is nanosecond-accurate and globally synchronized across all aircraft. SkyTalk's floor control algorithm uses GPS timestamps as the arbitration clock — no external NTP reference needed, no clock drift between sites."}]
2e:["$","p",null,{"children":"The comms library polls the DLS-140 GPS endpoint via HTTP on the local LAN:"}]
