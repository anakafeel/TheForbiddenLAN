",null,{"children":["\n",["$","li",null,{"children":"The team is building in a one-week hackathon. Every technology decision has to ship fast."}],"\n",["$","li",null,{"children":"The server must handle both REST (for admin/app control) and WebSocket (for real-time audio relay) on the same process."}],"\n",["$","li",null,{"children":"Data model is known and stable — 6 tables defined before any code was written."}],"\n",["$","li",null,{"children":["We need direct, predictable control over the database schema because key management depends on specific column semantics (","$L2b",", ","$L2c",")."]}],"\n","$L2d","\n"]}],"\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37"],"className":"prose"}]],"$L38","$L39","$L3a"]}]]}],"$L3b"]}]
