nk-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}],"\n",["$","blockquote",null,{"children":["\n",["$","p",null,{"children":["$","strong",null,{"children":"The interface disappears. The communication doesn't."}]}],"\n"]}],"\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21","\n","$L22","\n","$L23","\n","$L24","\n","$L25","\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a"],"className":"prose"}]],"$L2b","$L2c","$L2d"]}]]}],"$L2e"]}],["$L2f","$L30"],"$L31"]}],"loading":null,"isPartial":false}
b:["$","p",null,{"children":"A walkie-talkie has one job: let you speak and let you hear. The best radio handset is the one you stop thinking about — you press, you talk, you release. SkyTalk is software that has to feel like hardware."}]
c:["$","p",null,{"children":"This shapes every UI decision in the mobile app. If a screen element doesn't serve the act of communicating, it doesn't belong on the primary view."}]
d:["$","hr",null,{}]
e:["$","h2",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"apple-hig-alignment","children":[["$","a",null,{"data-card":"","href":"#apple-hig-alignment","className":"peer","children":"Apple HIG Alignment"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
f:["$","p",null,{"children":"SkyTalk mobile is built on React Native targeting iOS (and Android via the same codebase). We apply the three core Apple Human Interface Guidelines lenses throughout:"}]
10:["$","h3",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"clarity","children":[["$","a",null,{"data-card":"","href":"#clarity","className":"peer","children":"Clarity"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
11:["$","p",null,{"children":"The interface is immediately legible under stress:"}]
12:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"One large PTT button"}]," dominates the screen. There is no ambiguity about what to press."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Talkgroup name"}]," is displayed prominently at the top — you always know which channel you're on."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Floor state"}]," (who is transmitting) is shown in plain text, not abstract icons. \"Alice transmitting\" is better than a waveform icon the pilot has never seen before."]}],"\n",["$","li",null,{"children":"Font sizes are large. Cockpit lighting and gloves affect readability."}],"\n"]}]
13:["$","h3",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"deference","children":[["$","a",null,{"data-card":"","href":"#deference","className":"peer","children":"Deference"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
14:["$","p",null,{"children":"The UI steps back for the content (the communication):"}]
15:["$","ul",null,{"children":["\n",["$","li",null,{"children":"No gradients, decorative textures, or visual chrome that doesn't carry information."}],"\n",["$","li",null,{"children":"Status indicators (GPS lock, connection state) are peripheral — visible on a second glance, not demanding attention on first look."}],"\n",["$","li",null,{"children":["Color is used functionally: ",["$","strong",null,{"children":"green"}]," = you have the floor, ",["$","strong",null,{"children":"red"}]," = someone else has the floor, ",["$","strong",null,{"children":"grey"}]," = channel is free."]}],"\n"]}]
16:["$","h3",null,{"className":"flex scroll-m-28 flex-row items-center gap-2","id":"depth","children":[["$","a",null,{"data-card":"","href":"#depth","className":"peer","children":"Depth"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-link size-3.5 shrink-0 text-fd-muted-foreground opacity-0 transition-opacity peer-hover:opacity-100","aria-label":"Link to section","children":[["$","path","1cjeqo",{"d":"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"}],["$","path","19qd67",{"d":"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"}],"$undefined"]}]]}]
17:["$","p",null,{"children":"Navigation layers are flat:"}]
18:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Primary screen"}],": talkgroup + PTT button + floor status."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"One level deep"}],": talkgroup member list, text messages."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Settings"}],": separate, rarely accessed."]}],"\n"]}]
19:["$","p",null,{"children":"Pilots shouldn't navigate menus during critical phases of flight. Everything needed for normal operation is on one screen."}]
