4a:["$","p",null,{"children":["During development, the app can run without a server using ",["$","code",null,{"children":"EXPO_PUBLIC_MOCK_MODE=true"}],". In mock mode, a ",["$","code",null,{"children":"MockRelaySocket"}]," loopback replaces the real WebSocket — PTT audio is echoed back to the sender, simulating a one-person talkgroup. This lets the UI team develop without a running server."]}]
